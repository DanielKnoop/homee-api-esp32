{
    "name": "homee-api-esp32",
    "version": "0.3.0",
    "description": "Implements a virtual homee hub (homee-in-homee) on ESP32 and ESP8266. Exposes nodes and attributes over WebSocket and HTTP, handles UDP discovery, and pushes attribute updates to connected homee hubs in real time.",
    "keywords": "homee, vhih, virtual homee, homee-in-homee, smart home, esp32, esp8266",
    "build":
    {
      "libCompatMode": "strict"
    },
    "repository":
    {
      "type": "git",
      "url": "https://github.com/DanielKnoop/homee-api-esp32.git"
    },
    "authors":
    [
      {
        "name": "Daniel Knoop",
        "email": "code@knoop.in",
        "url": "https://github.com/DanielKnoop/homee-api-esp32",
        "maintainer": true
      }
    ],
    "license": "MIT",
    "homepage": "https://github.com/DanielKnoop/homee-api-esp32",
    "dependencies":
    [
      {
        "owner": "bblanchon",
        "name": "ArduinoJson",
        "version": "^7.4.3"
      },
      {
        "owner": "ESP32Async",
        "name": "ESPAsyncWebServer",
        "version": "^3.11.0",
        "platforms": ["espressif32"]
      },
      {
        "owner": "ESP32Async",
        "name": "AsyncTCP",
        "version": "^3.4.10",
        "platforms": ["espressif32"]
      },
      {
        "owner": "mathieucarbou",
        "name": "ESPAsyncWebServer",
        "version": "^3.6.0",
        "platforms": ["espressif8266"]
      },
      {
        "owner": "esphome",
        "name": "ESPAsyncTCP-esphome",
        "version": "^2.0.0",
        "platforms": ["espressif8266"]
      },
      {
        "owner": "me-no-dev",
        "name": "ESPAsyncUDP",
        "platforms": ["espressif8266"]
      }
    ],
    "frameworks": ["arduino"],
    "platforms": ["espressif32", "espressif8266"]
  }
